{
  "expo": {
    "name": "Servicons Mobile",
    "slug": "servicons-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "servicons-mobile",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Servicons registra tu ubicacion en cada reporte y alerta SOS para que el cliente y administradores puedan monitorear el servicio en tiempo real.",
        "NSCameraUsageDescription": "Servicons necesita la camara para tomar fotos de evidencia durante el monitoreo de custodia.",
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "googlemaps",
          "geo"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#E6F4FE"
      },
      "versionCode": 3,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.servicons.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "servicons-mobile"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Servicons necesita la camara para tomar fotos de evidencia durante el monitoreo de custodia."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Servicons registra tu ubicacion en cada reporte y alerta SOS para que el cliente y administradores puedan monitorear el servicio en tiempo real."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#F97316"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
